{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "AutoGrading.Identity",
    "Audience": "AutoGrading",
    "SigningKey": "CHANGE_ME_dev_only_signing_key_min_32_chars",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity"
          }
        ]
      },
      "catalog-classes-anonymous-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/classes",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/catalog"
          }
        ]
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/catalog"
          }
        ]
      },
      "submissions-route": {
        "ClusterId": "submission-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/submissions/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/submissions"
          }
        ]
      },
      "grading-route": {
        "ClusterId": "grading-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/grading/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/grading"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notifications"
          }
        ]
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5265"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5029"
          }
        }
      },
      "submission-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5226"
          }
        }
      },
      "grading-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5108"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5280"
          }
        }
      }
    }
  }
}