# Copy this file to .env and fill in real values before running `docker compose up`.
# Never commit the resulting .env file.

# --- SQL Server ---
SA_PASSWORD=Your_strong_password123!

# --- JWT ---
JWT_ISSUER=AutoGrading.Identity
JWT_AUDIENCE=AutoGrading
JWT_SIGNING_KEY=replace-with-a-long-random-signing-key-at-least-32-chars

# --- RabbitMQ ---
RABBITMQ_USER=autograding
RABBITMQ_PASSWORD=replace-with-rabbitmq-password

# --- MinIO ---
MINIO_ROOT_USER=autograding
MINIO_ROOT_PASSWORD=replace-with-minio-password

# --- OpenCode AI (model mimo-v2.5-free — vision-capable) ---
OPENCODE_API_KEY=replace-with-opencode-api-key
